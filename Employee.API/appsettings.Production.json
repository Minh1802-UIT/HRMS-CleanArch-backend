{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId:-} | {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowedOrigins": [
      "https://hrms-ui-kappa.vercel.app",
      "https://hrms-clean-arch-frontend.vercel.app",
      "http://localhost:4200"
    ]
  },
  "JwtSettings": {
    "DurationInMinutes": 30
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "nguyenvanminh180220@gmail.com",
    "SenderName": "HRMS Auto System",
    "Username": "nguyenvanminh180220@gmail.com"
  },
  "FrontendUrl": "https://hrms-clean-arch-frontend.vercel.app"
}