# ---------------------------------------------------------------------------
# .env.example — copy this file to .env and fill in real values.
# The .env file is listed in .gitignore and must NEVER be committed.
# ---------------------------------------------------------------------------

# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=CHANGE_ME_strong_password_here

# JWT signing key — must be at least 32 characters
JWT_SECRET_KEY=CHANGE_ME_min32chars_random_secret_key!!

# Redis authentication password
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@yourdomain.com
EMAIL_PASSWORD=CHANGE_ME_app_password_here

# CORS — production frontend origin (no trailing slash)
CORS_ALLOWED_ORIGINS=https://hrms.yourdomain.com

# Seeding default password (all freshly created employees use this until they reset)
SEEDING_DEFAULT_PASSWORD=CHANGE_ME_default_employee_password

# Docker Hub username — used by docker-compose.prod.yml to pull pre-built images
DOCKER_USERNAME=your-dockerhub-username
